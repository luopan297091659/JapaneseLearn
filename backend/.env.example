NODE_ENV=development
PORT=8002

# Timezone — 服务时区统一使用东京时间 (JST, UTC+9)
# 生产服务器若系统时区已是 Asia/Tokyo 可省略此行
TZ=Asia/Tokyo

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=japanese_learn
DB_USER=root
DB_PASSWORD=your_password

# JWT
JWT_SECRET=your_jwt_secret_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_change_in_production
JWT_REFRESH_EXPIRES_IN=30d

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=50mb

# News API (NHK Web Easy)
NHK_API_URL=https://www3.nhk.or.jp/news/easy

# SSL / HTTPS
SSL_CERT_PATH=./certs/cert.pem
SSL_KEY_PATH=./certs/key.pem

# CORS
ALLOWED_ORIGINS=https://139.196.44.6:8002,http://localhost:8002
